# Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PRICE_ID=price_xxxxx

# Anthropic Claude (for AI invoice generation)
ANTHROPIC_API_KEY=sk-ant-xxxxx
# For third-party API proxy, set custom base URL (e.g., https://api.deerapi.com)
# ANTHROPIC_BASE_URL=https://api.deerapi.com
# Model to use (optional, defaults to claude-sonnet-4-6 for deerapi.com)
# Available models on deerapi.com: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase (for database)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Google OAuth (for authentication)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
NEXTAUTH_URL=http://localhost:3000
# For Vercel deployment, set NEXTAUTH_URL to your production URL:
# NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-secret-key-here

# Email Authentication (for magic link login)
# Get RESEND_API_KEY from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
