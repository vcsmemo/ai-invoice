# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Database & Storage (Supabase)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# AI (Anthropic Claude)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx
# For third-party API proxy, set custom base URL (e.g., https://api.deerapi.com)
# ANTHROPIC_BASE_URL=https://api.deerapi.com
# Model to use (optional, defaults to claude-sonnet-4-6 for deerapi.com)
# Available models on deerapi.com: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Payments (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# -----------------------------------------------------------------------------
# Email Service (Resend)
# -----------------------------------------------------------------------------
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
# From email address (must be verified in Resend dashboard)
EMAIL_FROM=noreply@yourdomain.com
# Public: Display contact email in footer
NEXT_PUBLIC_CONTACT_EMAIL=contact@yourdomain.com
